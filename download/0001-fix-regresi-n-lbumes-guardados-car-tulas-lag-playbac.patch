   const imgRef = useRef(null);
-  const real = !failed && src ? hiResCover(src, size) : FALLBACK_COVER;
+  // Si el src viene vacío o es el propio fallback, no lo pases por hiResCover
+  // (rompería el data: URL del SVG). Y si ya falló, directamente al fallback.
+  const isHttpSrc = src && typeof src === 'string' && src.length > 0 && !src.startsWith('data:');
