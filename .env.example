# ─────────────────────────────────────────────────────────────
# VELOCITY MUSIC — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────
PORT=3000

# ── Seguridad ─────────────────────────────────────────────────
# Secreto JWT. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Duración del JWT en días (default 30, rango 1..3650).
# Antes era ~10 años (indefinido). Ahora es configurable para acortar
# la ventana de exposición si un token se filtra.
# JWT_TTL_DAYS=30

# Clave del panel de administración.
# Acepta AMBOS métodos de autenticación:
#   - Header `X-Admin-Key: <key>` (preferido, no aparece en logs)
#   - Query param `?key=<key>` (deprecado, emite warning en stderr)
# Mínimo 8 caracteres. Sin esta variable el panel queda DESHABILITADO.
ADMIN_KEY=cambia-esto-por-una-clave-admin-segura

# ── CORS ──────────────────────────────────────────────────────
# Origen permitido para CORS en producción.
# OBLIGATORIO en prod: si no se configura y NODE_ENV=production, CORS
# rechaza todas las peticiones cross-origin (fail-closed).
# En desarrollo puede dejarse en blanco (acepta todos los orígenes).
# Ejemplo: ALLOWED_ORIGIN=https://velocitymusic.uk
ALLOWED_ORIGIN=

# ── PostgreSQL ────────────────────────────────────────────────
# Activar PostgreSQL en lugar del almacén JSON.
# OBLIGATORIO para modo cluster y producción multiusuario.
USE_POSTGRES=1

# Cadena de conexión completa (Supabase, Neon, Render, etc.).
# Tiene prioridad sobre las variables individuales de abajo.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Alternativamente, variables individuales:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=velocity_music

# Deshabilitar SSL (solo para localhost / desarrollo sin TLS).
# En producción dejar sin definir o poner PGSSL=1.
# PGSSL=0

# Tamaño máximo del pool de conexiones por proceso/worker.
# Supabase Free permite 20 conexiones simultáneas en total.
# Con 8 workers: 2 por worker = 16 total (margen seguro).
# Ajustar si tienes un plan con más conexiones permitidas.
PG_MAX_POOL_SIZE=2

# Tiempo (ms) antes de cerrar una conexión inactiva del pool.
# Supabase cierra idle connections a los ~60 s; ponemos 45 s para
# cerrarlas nosotros primero y evitar "Connection terminated unexpectedly".
PG_IDLE_TIMEOUT_MS=45000

# Tiempo máximo (ms) para adquirir una conexión del pool.
# Si no hay conexiones disponibles en este tiempo, la query lanza error.
PG_CONN_TIMEOUT_MS=10000

# ── Modo de resolución ────────────────────────────────────────
# Forzar modo de resolución (opcional). Por defecto: full si yt-dlp está disponible.
# RESOLUTION_MODE=full

# ── Cluster ───────────────────────────────────────────────────
# Activar modo cluster (requiere USE_POSTGRES=1).
CLUSTER=1

# Número de workers. Por defecto: número de cores de CPU.
# WEB_CONCURRENCY=8

# Total de procesos yt-dlp simultáneos (repartidos entre workers).
RESOLVE_CONCURRENCY=8
