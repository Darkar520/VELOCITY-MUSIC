# ─────────────────────────────────────────────────────────────
# VELOCITY MUSIC — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────

# Puerto del servidor (Render lo asigna automáticamente)
PORT=3000

# Secreto para firmar tokens JWT. Genera uno seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# OBLIGATORIO en producción. Si no se configura, el servidor lanza un error de arranque.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Origen permitido para CORS (dominio de Vercel en producción)
# En desarrollo puede dejarse en blanco (acepta todos los orígenes)
# Ejemplo: ALLOWED_ORIGIN=https://velocity-music.vercel.app
ALLOWED_ORIGIN=

# Activar PostgreSQL en lugar de almacén JSON (necesario en producción multiusuario)
# USE_POSTGRES=1

# URL de conexión a PostgreSQL (Render Postgres, Supabase, etc.)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Modo de resolución forzado (opcional, por defecto: full si yt-dlp está disponible)
# RESOLUTION_MODE=full
