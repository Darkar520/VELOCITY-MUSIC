# ─────────────────────────────────────────────────────────────
# VELOCITY MUSIC — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Seguridad ─────────────────────────────────────────────────
# Secreto JWT (+ firma HMAC de stream). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Duración del JWT en días (default 30, rango 1..3650).
# JWT_TTL_DAYS=30

# Clave del panel de administración y de POST /api/setup/extractor/install (prod).
# Header X-Admin-Key (preferido) o ?key= (deprecado).
# Mínimo 8 caracteres. Sin esta variable el panel queda DESHABILITADO.
ADMIN_KEY=cambia-esto-por-una-clave-admin-segura

# ── CORS ──────────────────────────────────────────────────────
# OBLIGATORIO en prod. Fail-closed si falta y NODE_ENV=production.
ALLOWED_ORIGIN=https://velocitymusic.uk

# ── Google OAuth (opcional) ───────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Spotify import (opcional; playlists privadas / Made For You) ─
# Crea UNA app en https://developer.spotify.com/dashboard
# Redirect URI: https://velocitymusic.uk/  (y http://localhost:3000/ en dev)
# Scopes usados: playlist-read-private playlist-read-collaborative user-library-read
# El Client ID es público (Implicit Grant); NO pongas el Client Secret aquí.
SPOTIFY_CLIENT_ID=

# ── PostgreSQL ────────────────────────────────────────────────
USE_POSTGRES=1
DATABASE_URL=postgresql://velocity:CAMBIAR_PASSWORD@localhost:5432/velocity_music
PGSSL=0
PG_MAX_POOL_SIZE=3
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000

# ── Cluster ───────────────────────────────────────────────────
CLUSTER=1
# Workers Node (default seguro en PC de escritorio: 2). No uses el n. de cores.
WEB_CONCURRENCY=2
RESOLVE_CONCURRENCY=8
# Milisegundos de espera entre el arranque de cada worker (evita race condition
# de yt-dlp: 8 procesos simultáneos en arranque → Windows los mata → degraded).
# Con 500 ms y 8 workers el coste de arranque extra es ~3,5 s. Pon 0 para desactivar.
WORKER_STAGGER_MS=500

# ── Extractor yt-dlp ──────────────────────────────────────────
# Auto-actualización de yt-dlp (YouTube cambia defensas casi cada semana;
# un binario viejo es la causa #1 de "no se pudo reproducir"). 0 para desactivar.
YTDLP_AUTO_UPDATE=1
# Cada cuántas horas re-verificar si hay versión nueva de yt-dlp.
YTDLP_UPDATE_INTERVAL_HOURS=12
# Tope (ms) que espera la búsqueda combinada por SoundCloud antes de devolver
# solo YouTube Music. SoundCloud (scsearch vía yt-dlp) tarda ~5-6 s; sin este
# tope la búsqueda entera se ralentiza y provoca "No se pudo buscar" intermitente.
SC_SEARCH_CAP_MS=1200

# ── SMTP (opcional; sin esto el mailer es no-op) ──────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Velocity Music <noreply@example.com>
