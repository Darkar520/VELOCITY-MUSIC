# ── Variables de entorno (nunca al repo) ──────────────────────
.env
.env.local
.env.*.local

# ── Dependencias ──────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ── Datos y backups de la base de datos JSON ──────────────────
data/
data-staging/
*.bak
*.pre-recover

# ── Build de staging del frontend (Cloudflare Pages preview) ──
frontend/dist/

# ── Binarios descargados en runtime (yt-dlp) ──────────────────
bin/

# ── Build del frontend (generado por npm run build) ───────────
/public/

# ── Logs ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Sistema operativo ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editores ──────────────────────────────────────────────────
.vscode/
*.swp
*.swo

# ── Artefactos de desarrollo interno (Kiro specs) ─────────────
.kiro/

# ── Skills / sesión local ─────────────────────────────────────
skills/

# ── Basura y scratch ──────────────────────────────────────────
tool-results/
upload/
download/
scratch/

# ── Apple Music Decrypt (tools/amd/) ─────────────────────────────────────────
# El .venv de Python y las dependencias binarias no se committean (son ~300MB)
tools/amd/app/.venv/
tools/amd/app/deps/
tools/amd/app/downloads/
tools/amd/app/.git/
tools/amd/app/.idea/
tools/amd/app/assets/wrapper-manager.qcow2
# El ZIP de instalación
tools/amd/*.zip
# Caché de archivos descifrados por AMD (generado en runtime)
tools/amd/cache/
